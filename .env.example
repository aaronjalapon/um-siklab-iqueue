# =============================================================================
# IQueue — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# --- Database ---
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/iqueue

# --- QR Boarding Pass Signing ---
# Generate with: python scripts/generate_qr_keys.py
# WARNING: Rotating this key invalidates all existing boarding passes!
QR_HMAC_SECRET=

# --- Machine Learning ---
# Paths to serialized forecasting model artifacts
PROPHET_MODEL_PATH=backend/app/services/forecasting/artifacts/prophet_model.pkl
LSTM_MODEL_PATH=backend/app/services/forecasting/artifacts/lstm_model.pt

# --- Chatbot ---
# Path to the fine-tuned XLM-RoBERTa intent classifier
CHATBOT_MODEL_PATH=ml/chatbot/artifacts/xlm-roberta-iqueue

# DeepSeek API key (only needed for synthetic dataset generation)
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Hugging Face API token for hosted inference (optional during prototype)
# Get one at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=

# --- Application ---
# Enable debug mode (disable in production)
DEBUG=true

# Django-style secret key for session signing
SECRET_KEY=

# Comma-separated list of allowed CORS origins (no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- API ---
# Base URL prefix for the API
API_V1_PREFIX=/api/v1

# --- Server ---
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000
